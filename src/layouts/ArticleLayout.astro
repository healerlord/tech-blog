---
import BaseLayout from "./BaseLayout.astro";
import type { BlogPost } from "../lib/content";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(post.data.publishedAt);
---

<BaseLayout title={`${post.data.title} · KYRIE.DEV`} description={post.data.description}>
  <article class="container article-shell">
    <header class="article-header">
      <p class="article-kicker mono">ARTICLE / {post.data.tags.join(" · ")}</p>
      <h1>{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="article-meta mono">
        <time datetime={post.data.publishedAt.toISOString()}>{formattedDate}</time>
        <span>{post.readingMinutes} MIN READ</span>
      </div>
    </header>

    <div class="article-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    padding-block: 72px 110px;
  }

  .article-header {
    max-width: 880px;
    padding-bottom: 38px;
    border-bottom: 1px solid var(--ink);
  }

  .article-kicker {
    margin: 0 0 18px;
    color: var(--blue);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 840px;
    font-size: 3.6rem;
    line-height: 1.02;
    letter-spacing: 0;
  }

  .article-description {
    max-width: 680px;
    margin: 24px 0 26px;
    color: var(--muted-ink);
    font-size: 1rem;
    line-height: 1.75;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--muted-ink);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .article-body {
    max-width: 760px;
    margin-top: 50px;
    font-size: 1rem;
    line-height: 1.95;
  }

  .article-body :global(h2) {
    margin: 56px 0 18px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    font-size: 1.65rem;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .article-body :global(h3) {
    margin: 38px 0 14px;
    font-size: 1.25rem;
    letter-spacing: 0;
  }

  .article-body :global(p),
  .article-body :global(ul),
  .article-body :global(ol) {
    margin-block: 0 24px;
  }

  .article-body :global(a) {
    color: var(--blue);
    border-bottom: 1px solid currentColor;
  }

  .article-body :global(code) {
    padding: 0.12em 0.34em;
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .article-body :global(pre) {
    margin-block: 28px;
    padding: 22px;
    overflow-x: auto;
    border-radius: 0;
  }

  .article-body :global(pre code) {
    padding: 0;
    background: transparent;
  }

  .article-body :global(blockquote) {
    margin: 32px 0;
    padding: 8px 0 8px 22px;
    border-left: 5px solid var(--signal);
    color: var(--muted-ink);
  }

  @media (max-width: 820px) {
    .article-shell {
      padding-block: 52px 80px;
    }

    h1 {
      font-size: 2.65rem;
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 2.15rem;
    }

    .article-body {
      font-size: 0.96rem;
    }
  }
</style>
