---
import { ArrowRight } from "@lucide/astro";

import type { Project } from "../data/projects";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, "")}`;
---

<section class="project-band">
  <div class="container project-layout">
    <div class="project-intro">
      <p class="mono">精选项目 / {String(projects.length).padStart(2, "0")}</p>
      <h2>正在构建，<br />也持续复盘。</h2>
    </div>

    <div class="project-list">
      {projects.length === 0 ? (
        <p>项目记录正在整理。</p>
      ) : (
        projects.map((project) => (
          <a id={project.id} class="project-row" href={withBase(project.href)}>
            <span>
              <strong>{project.name}</strong>
              <small>{project.description}</small>
            </span>
            <em>{project.stack}</em>
            <ArrowRight size={18} stroke-width={2} aria-hidden="true" />
          </a>
        ))
      )}
    </div>
  </div>
</section>

<style>
  .project-band {
    padding-block: 58px 64px;
    background: #12130f;
    color: #f3f3ee;
  }

  .project-layout {
    display: grid;
    grid-template-columns: 0.62fr 1.38fr;
    gap: 54px;
  }

  .project-intro p {
    margin: 0;
    color: #b6bab0;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .project-intro h2 {
    margin: 15px 0 0;
    font-size: 2rem;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .project-list {
    border-top: 1px solid #65695f;
  }

  .project-row {
    display: grid;
    grid-template-columns: 1fr 150px 20px;
    gap: 20px;
    align-items: center;
    min-height: 94px;
    border-bottom: 1px solid #65695f;
  }

  .project-row > span {
    display: grid;
    gap: 4px;
  }

  .project-row strong {
    font-size: 1rem;
  }

  .project-row small,
  .project-row em {
    color: #b6bab0;
    font-size: 0.72rem;
    font-style: normal;
  }

  .project-row svg {
    color: #dfff00;
    transition: transform 160ms ease;
  }

  .project-row:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 820px) {
    .project-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 560px) {
    .project-row {
      grid-template-columns: 1fr 20px;
    }

    .project-row em {
      display: none;
    }
  }
</style>
