---
import { ArrowRight } from "@lucide/astro";

import type { BlogPost } from "../lib/content";
import { joinBase } from "../lib/urls";

interface Props {
  posts: BlogPost[];
  heading?: string;
  showAllLink?: boolean;
  startIndex?: number;
}

const {
  posts,
  heading = "最新文章",
  showAllLink = false,
  startIndex = 0,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", { month: "2-digit", day: "2-digit" })
    .format(date)
    .replace("/", ".");
---

<section class="post-list">
  <div class="section-heading">
    <h2>{heading}</h2>
    {showAllLink && (
      <a href={joinBase(base, "articles/")}>
        查看全部 {posts.length > 4 ? posts.length : ""} <ArrowRight size={15} stroke-width={2} aria-hidden="true" />
      </a>
    )}
  </div>

  <div class="post-rows">
    {posts.length === 0 ? (
      <p class="empty-state">这里还没有发布文章。</p>
    ) : (
      posts.map((post, index) => (
        <article class="post-row">
          <span class="post-index mono">{String(startIndex + index + 1).padStart(2, "0")}</span>
          <h3><a href={joinBase(base, `articles/${post.id}/`)}>{post.data.title}</a></h3>
          <span class="post-tag mono">{post.data.tags.slice(0, 2).join(" / ")}</span>
          <span class="post-meta mono">{formatDate(post.data.publishedAt)} / {post.readingMinutes} MIN</span>
        </article>
      ))
    )}
  </div>
</section>

<style>
  .post-list {
    padding-block: 54px 66px;
    border-top: 1px solid var(--ink);
  }

  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  h2 {
    margin: 0;
    font-size: 1.8rem;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .section-heading > a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.75rem;
    font-weight: 750;
  }

  .section-heading > a:hover {
    color: var(--blue);
  }

  .post-row {
    display: grid;
    grid-template-columns: 42px 1fr 154px 98px;
    gap: 20px;
    align-items: center;
    min-height: 92px;
    border-top: 1px solid var(--line);
  }

  .post-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .post-index,
  .post-tag,
  .post-meta {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .post-index,
  .post-meta {
    color: var(--muted-ink);
  }

  .post-tag {
    color: var(--blue);
  }

  .post-meta {
    text-align: right;
  }

  h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.3;
    letter-spacing: 0;
  }

  h3 a:hover {
    color: var(--blue);
  }

  h3 a {
    overflow-wrap: anywhere;
  }

  .empty-state {
    padding-block: 30px;
    border-top: 1px solid var(--line);
    color: var(--muted-ink);
  }

  @media (max-width: 760px) {
    .post-row {
      grid-template-columns: 32px 1fr auto;
      padding-block: 18px;
    }

    .post-tag {
      display: none;
    }

    .post-meta {
      font-size: 0.58rem;
    }
  }

  @media (max-width: 520px) {
    .post-row {
      grid-template-columns: 24px 1fr;
      gap: 12px;
    }

    .post-meta {
      display: none;
    }

    h3 {
      font-size: 1rem;
    }
  }
</style>
