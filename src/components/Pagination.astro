---
import { ArrowLeft, ArrowRight } from "@lucide/astro";

import { topicPagePath } from "../lib/topics";
import { joinBase } from "../lib/urls";

interface Props {
  slug: string;
  page: number;
  pageCount: number;
}

const { slug, page, pageCount } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageUrl = (target: number) =>
  joinBase(base, `topics/${topicPagePath(slug, target)}/`);
---

{pageCount > 1 && (
  <nav class="pagination mono" aria-label="专题分页">
    {page > 1 ? (
      <a href={pageUrl(page - 1)} rel="prev">
        <ArrowLeft size={17} stroke-width={2} aria-hidden="true" /> 上一页
      </a>
    ) : (
      <span aria-hidden="true"></span>
    )}

    <strong>PAGE {page} / {pageCount}</strong>

    {page < pageCount ? (
      <a href={pageUrl(page + 1)} rel="next">
        下一页 <ArrowRight size={17} stroke-width={2} aria-hidden="true" />
      </a>
    ) : (
      <span aria-hidden="true"></span>
    )}
  </nav>
)}

<style>
  .pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .pagination a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    min-height: 40px;
    padding-inline: 12px;
    border: 1px solid var(--ink);
  }

  .pagination a:last-child {
    justify-self: end;
  }

  .pagination a:hover {
    background: var(--signal);
    color: #12130f;
  }

  .pagination strong {
    color: var(--muted-ink);
  }

  @media (max-width: 480px) {
    .pagination {
      grid-template-columns: 1fr 1fr;
    }

    .pagination strong {
      grid-column: 1 / -1;
      grid-row: 1;
      text-align: center;
    }
  }
</style>
