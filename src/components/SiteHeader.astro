---
import { Menu, Moon, Search, Sun, X } from "@lucide/astro";
import { joinBase } from "../lib/urls";

const base = import.meta.env.BASE_URL;
const navigation = [
  { label: "文章", href: joinBase(base, "articles/") },
  { label: "专题", href: joinBase(base, "topics/") },
  { label: "项目", href: joinBase(base, "projects/") },
  { label: "关于", href: joinBase(base, "about/") },
];
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a class="site-brand mono" href={joinBase(base, "/")} aria-label="KYRIE.DEV 首页">
      KYRIE / DEV
    </a>

    <nav class="desktop-nav" aria-label="主导航">
      {navigation.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="header-tools">
      <button class="icon-button mobile-only" type="button" data-menu-toggle aria-controls="mobile-navigation" aria-expanded="false">
        <span class="icon-slot" data-menu-open-icon><Menu size={18} stroke-width={1.8} /></span>
        <span class="icon-slot" data-menu-close-icon hidden><X size={18} stroke-width={1.8} /></span>
        <span class="sr-only">打开导航</span>
      </button>
      <button class="icon-button" type="button" data-search-open aria-label="搜索文章">
        <Search size={18} stroke-width={1.8} />
      </button>
      <button class="icon-button" type="button" data-theme-toggle aria-label="切换颜色主题">
        <span class="icon-slot" data-theme-light-icon><Sun size={18} stroke-width={1.8} /></span>
        <span class="icon-slot" data-theme-dark-icon hidden><Moon size={18} stroke-width={1.8} /></span>
      </button>
    </div>
  </div>

  <nav id="mobile-navigation" class="mobile-nav" aria-label="移动端导航" hidden>
    <div class="container mobile-nav-inner">
      {navigation.map((item, index) => (
        <a href={item.href}>
          <span class="mono">0{index + 1}</span>
          <strong>{item.label}</strong>
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  const menuToggle = header?.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const mobileNavigation = header?.querySelector<HTMLElement>("#mobile-navigation");
  const openIcon = menuToggle?.querySelector<HTMLElement>("[data-menu-open-icon]");
  const closeIcon = menuToggle?.querySelector<HTMLElement>("[data-menu-close-icon]");

  const setMenuOpen = (open: boolean) => {
    if (!menuToggle || !mobileNavigation || !openIcon || !closeIcon) return;
    menuToggle.setAttribute("aria-expanded", String(open));
    menuToggle.querySelector(".sr-only")!.textContent = open ? "关闭导航" : "打开导航";
    mobileNavigation.hidden = !open;
    openIcon.hidden = open;
    closeIcon.hidden = !open;
  };

  menuToggle?.addEventListener("click", () => {
    setMenuOpen(menuToggle.getAttribute("aria-expanded") !== "true");
  });

  mobileNavigation?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenuOpen(false);
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 20;
    background: var(--paper);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 72px;
    border-bottom: 1px solid var(--ink);
  }

  .site-brand {
    width: max-content;
    font-size: 0.85rem;
    font-weight: 800;
  }

  .desktop-nav,
  .header-tools {
    display: flex;
    align-items: center;
  }

  .icon-slot {
    display: inline-flex;
  }

  .icon-slot[hidden] {
    display: none;
  }

  .desktop-nav {
    gap: 28px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .desktop-nav a {
    padding-block: 5px;
    border-bottom: 2px solid transparent;
  }

  .desktop-nav a:hover {
    border-color: var(--ink);
  }

  .header-tools {
    justify-content: flex-end;
    gap: 8px;
  }

  .mobile-only,
  .mobile-nav {
    display: none;
  }

  @media (max-width: 820px) {
    .header-inner {
      grid-template-columns: 1fr auto;
    }

    .desktop-nav {
      display: none;
    }

    .mobile-only {
      display: inline-flex;
    }

    .mobile-nav:not([hidden]) {
      display: block;
      border-bottom: 1px solid var(--ink);
      background: var(--paper);
    }

    .mobile-nav-inner {
      padding-block: 12px 22px;
    }

    .mobile-nav a {
      display: grid;
      grid-template-columns: 44px 1fr;
      align-items: center;
      min-height: 52px;
      border-bottom: 1px solid var(--line);
    }

    .mobile-nav a:last-child {
      border-bottom: 0;
    }

    .mobile-nav span {
      color: var(--muted-ink);
      font-size: 0.68rem;
    }
  }

  @media (max-width: 390px) {
    .header-tools {
      gap: 5px;
    }

    .icon-button {
      width: 38px;
      height: 38px;
      flex-basis: 38px;
    }
  }
</style>
