---
import { joinBase } from "../lib/urls";

const base = import.meta.env.BASE_URL;
---

<section class="container hero-intro">
  <div class="hero-copy">
    <p class="hero-eyebrow mono"><span aria-hidden="true"></span>Software engineer · Shanghai</p>
    <h1>KYRIE.DEV</h1>
    <p class="hero-statement">
      记录 Java、AI 工程与系统设计，<mark>把复杂系统讲清楚。</mark>
    </p>
  </div>

  <aside class="hero-profile" aria-label="作者简介">
    <p class="profile-label mono">ABOUT / 001</p>
    <p>关注真实生产环境里的设计决策、失败路径和工程边界。这里没有速成教程，只有可复用的经验。</p>
    <div class="profile-links mono">
      <a href="https://github.com/healerlord" rel="me">GITHUB ↗</a>
      <a href={joinBase(base, "about/")}>ABOUT →</a>
      <a href={joinBase(base, "rss.xml")}>RSS ↗</a>
    </div>
  </aside>
</section>

<style>
  .hero-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(220px, 0.45fr);
    gap: 56px;
    padding-block: 68px 58px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: var(--muted-ink);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero-eyebrow span {
    width: 10px;
    height: 10px;
    background: var(--signal);
    border: 1px solid var(--ink);
  }

  h1 {
    margin: 16px 0 18px;
    font-size: 4.8rem;
    line-height: 0.9;
    letter-spacing: 0;
  }

  .hero-statement {
    max-width: 760px;
    margin: 0;
    font-size: 1.8rem;
    line-height: 1.18;
    font-weight: 680;
  }

  mark {
    position: relative;
    z-index: 0;
    background: transparent;
    color: inherit;
  }

  mark::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -2px;
    bottom: 1px;
    left: -2px;
    height: 34%;
    background: var(--signal);
  }

  .hero-profile {
    align-self: end;
    padding-top: 15px;
    border-top: 1px solid var(--ink);
  }

  .profile-label {
    margin: 0;
    color: var(--muted-ink);
    font-size: 0.66rem;
    font-weight: 700;
  }

  .hero-profile > p:nth-child(2) {
    margin: 14px 0 22px;
    font-size: 0.86rem;
    line-height: 1.7;
  }

  .profile-links {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .profile-links a:hover {
    color: var(--blue);
  }

  @media (max-width: 820px) {
    .hero-intro {
      grid-template-columns: 1fr;
      gap: 42px;
      padding-block: 48px 40px;
    }

    h1 {
      font-size: 3.75rem;
    }

    .hero-statement {
      max-width: 600px;
      font-size: 1.45rem;
    }

    .hero-profile {
      max-width: 430px;
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 3rem;
    }

    .hero-statement {
      font-size: 1.22rem;
    }
  }
</style>
