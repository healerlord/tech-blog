---
import "../../styles/global.css";
import "../../styles/write.css";

// In dev the CSP would block the Astro toolbar's inline scripts; the
// production bundle contains a single self-hosted module script.
const isDev = import.meta.env.DEV;
const csp = [
  "default-src 'self'",
  "script-src 'self'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: blob:",
  "font-src 'self' data:",
  "connect-src 'self' https://api.github.com",
  "worker-src 'self' blob:",
  "object-src 'none'",
  "base-uri 'self'",
].join("; ");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    {!isDev && <meta http-equiv="Content-Security-Policy" content={csp} />}
    <title>KYRIE.DEV 写作台</title>
  </head>
  <body>
    <div id="write-app" class="write-app">
      <aside class="library">
        <header class="library-head">
          <p class="library-brand">KYRIE / DEV · 写作台</p>
          <button
            id="new-post-button"
            class="ghost-button"
            type="button"
            aria-label="新建文章"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M8 2v12M2 8h12"
                stroke="currentColor"
                stroke-width="1.6"></path>
            </svg>
          </button>
        </header>
        <div class="library-search">
          <input
            id="library-filter"
            type="text"
            placeholder="筛选文章…"
            autocomplete="off"
          />
        </div>
        <ul id="library-list" class="post-list"></ul>
        <footer id="library-foot" class="library-foot">
          正在连接写作后端…
        </footer>
      </aside>

      <main class="workspace">
        <header class="workbar">
          <button
            id="toggle-library"
            class="ghost-button"
            type="button"
            aria-label="切换文章列表"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <rect
                x="1.5"
                y="2.5"
                width="13"
                height="11"
                stroke="currentColor"
                stroke-width="1.4"></rect>
              <path d="M6 2.5v11" stroke="currentColor" stroke-width="1.4"
              ></path>
            </svg>
          </button>
          <span id="doc-crumb" class="doc-crumb">写作台</span>
          <span id="backend-badge" class="backend-badge"></span>
          <span class="workbar-spacer"></span>
          <span id="save-status" class="save-status" data-state="idle"></span>
          <span id="doc-state" class="doc-state"></span>
          <button id="save-button" class="solid-button save-button" type="button">
            保存
          </button>
          <button
            id="logout-button"
            class="ghost-button"
            type="button"
            aria-label="退出 GitHub 登录"
            hidden
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M6 2H3v12h3M10 5l3 3-3 3M13 8H6"
                stroke="currentColor"
                stroke-width="1.5"></path>
            </svg>
          </button>
          <button
            id="open-settings"
            class="ghost-button"
            type="button"
            aria-label="文章设置"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M2 4.5h12M2 8h12M2 11.5h12"
                stroke="currentColor"
                stroke-width="1.4"></path>
              <circle cx="10.5" cy="4.5" r="1.6" fill="var(--paper)"
                stroke="currentColor" stroke-width="1.4"></circle>
              <circle cx="5.5" cy="8" r="1.6" fill="var(--paper)"
                stroke="currentColor" stroke-width="1.4"></circle>
              <circle cx="11.5" cy="11.5" r="1.6" fill="var(--paper)"
                stroke="currentColor" stroke-width="1.4"></circle>
            </svg>
          </button>
        </header>

        <div class="scroll-area">
          <div id="sheet" class="sheet" hidden>
            <input
              id="doc-title"
              class="doc-title"
              type="text"
              placeholder="无标题"
              autocomplete="off"
            />
            <button id="meta-line" class="doc-meta-line" type="button">
              <span id="meta-date"></span>
              <span id="meta-tags"></span>
              <span>· 编辑元信息</span>
            </button>
            <hr class="sheet-rule" />
            <div id="editor-host"></div>
          </div>
          <div id="workspace-empty" class="workspace-empty" hidden>
            还没有文章 · 点击左上角 + 开始写第一篇
          </div>
        </div>

        <aside id="settings" class="settings" aria-label="文章设置">
          <header class="settings-head">
            <h2>文章设置</h2>
            <button
              id="close-settings"
              class="ghost-button"
              type="button"
              aria-label="关闭设置"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path
                  d="M2 2l10 10M12 2L2 12"
                  stroke="currentColor"
                  stroke-width="1.6"></path>
              </svg>
            </button>
          </header>
          <div class="settings-body">
            <div id="settings-errors" class="settings-errors"></div>
            <div class="field">
              <label for="f-slug">文件</label>
              <input id="f-slug" type="text" readonly />
              <p class="field-hint">发布后 slug 不可修改。</p>
            </div>
            <div class="field">
              <label for="f-description">摘要</label>
              <textarea id="f-description"></textarea>
              <p class="field-hint">用于列表、搜索和 SEO。</p>
            </div>
            <div class="field">
              <label for="f-published">发布日期</label>
              <input id="f-published" type="date" />
            </div>
            <div class="field">
              <span class="field-label">专题</span>
              <div id="f-tags" class="tag-choices"></div>
            </div>
            <div class="switch-field">
              <span class="switch-label">保存为草稿</span>
              <input id="f-draft" type="checkbox" />
            </div>
            <div class="switch-field">
              <span class="switch-label">首页推荐</span>
              <input id="f-featured" type="checkbox" />
            </div>
            <div class="field">
              <label for="f-visual-alt">技术视觉说明</label>
              <textarea id="f-visual-alt"></textarea>
              <p class="field-hint">仅首页推荐文章必填。</p>
            </div>
          </div>
        </aside>

        <div id="gate" class="local-only visible">
          <div class="panel">
            <div id="gate-boot">
              <h2>正在连接写作后端…</h2>
              <p>本地开发环境自动使用文件模式。</p>
            </div>
            <div id="gate-login" hidden>
              <h2>连接 GitHub 开始写作</h2>
              <p>
                粘贴一个 Fine-grained Token（仅需 tech-blog 仓库的
                Contents 读写权限）。Token 只保存在当前浏览器中。
              </p>
              <div class="field gate-field">
                <input
                  id="gate-token"
                  type="password"
                  placeholder="github_pat_…"
                  autocomplete="off"
                />
              </div>
              <button id="gate-submit" class="solid-button" type="button">
                连接 GitHub
              </button>
              <p id="gate-error" class="settings-errors"></p>
              <p class="field-hint">
                在 GitHub「Settings → Developer settings → Fine-grained
                tokens」中生成，保存和发布会以 commit 形式写入仓库并触发部署。
              </p>
            </div>
          </div>
        </div>
      </main>
    </div>

    <dialog id="new-post-dialog" class="new-post-dialog">
      <form id="np-form" method="dialog" novalidate>
        <h2>新建文章</h2>
        <div class="field">
          <label for="np-title">标题</label>
          <input id="np-title" type="text" autocomplete="off" />
        </div>
        <div class="field">
          <label for="np-slug">URL Slug</label>
          <input
            id="np-slug"
            type="text"
            autocomplete="off"
            placeholder="agent-runtime-boundaries"
          />
          <p class="field-hint">
            小写英文、数字和单个连字符，发布后不可修改。
          </p>
        </div>
        <div class="field">
          <span class="field-label">专题</span>
          <div id="np-tags" class="tag-choices"></div>
        </div>
        <p id="np-error" class="settings-errors"></p>
        <div class="dialog-actions">
          <button id="np-cancel" class="text-button" type="button">
            取消
          </button>
          <button class="solid-button" type="submit">创建草稿</button>
        </div>
      </form>
    </dialog>

    <script>
      import "../../lib/write-app";
    </script>
  </body>
</html>
