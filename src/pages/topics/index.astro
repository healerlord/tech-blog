---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, type BlogPost } from "../../lib/content";

const posts = await getPublishedPosts();
const topicMap = new Map<string, BlogPost[]>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    topicMap.set(tag, [...(topicMap.get(tag) ?? []), post]);
  }
}

const topics = [...topicMap.entries()].sort((left, right) =>
  left[0].localeCompare(right[0], "zh-CN"),
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="专题 · KYRIE.DEV" description="按工程主题浏览 KYRIE.DEV 的技术文章。">
  <section class="container page-shell">
    <p class="page-kicker">Topics / {String(topics.length).padStart(2, "0")}</p>
    <h1 class="page-title">专题索引</h1>
    <p class="page-lede">主题不是标签堆积，而是同一类工程问题在不同上下文里的连续观察。</p>

    <div class="topic-list">
      {topics.map(([topic, topicPosts], index) => (
        <section id={topic.toLocaleLowerCase("en-US").replaceAll(" ", "-")} class="topic-row">
          <div class="topic-name">
            <span class="mono">{String(index + 1).padStart(2, "0")}</span>
            <h2>{topic}</h2>
            <small class="mono">{topicPosts.length} POSTS</small>
          </div>
          <div class="topic-posts">
            {topicPosts.map((post) => (
              <a href={`${base}articles/${post.id}/`}>{post.data.title}</a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .topic-list {
    margin-top: 62px;
    border-top: 1px solid var(--ink);
  }

  .topic-row {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: 40px;
    padding-block: 30px;
    border-bottom: 1px solid var(--line);
  }

  .topic-name {
    display: grid;
    grid-template-columns: 34px 1fr auto;
    gap: 12px;
    align-items: baseline;
  }

  .topic-name > span,
  .topic-name small {
    color: var(--muted-ink);
    font-size: 0.65rem;
    font-weight: 700;
  }

  h2 {
    margin: 0;
    font-size: 1.35rem;
    letter-spacing: 0;
  }

  .topic-posts {
    display: grid;
    gap: 10px;
  }

  .topic-posts a {
    width: fit-content;
    font-size: 0.9rem;
  }

  .topic-posts a:hover {
    color: var(--blue);
  }

  @media (max-width: 760px) {
    .topic-row {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
</style>
