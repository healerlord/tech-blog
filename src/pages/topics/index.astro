---
import { ArrowRight } from "@lucide/astro";

import { topicDefinitions } from "../../data/topics";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/content";
import { buildTopicGroups } from "../../lib/topics";
import { joinBase } from "../../lib/urls";

const posts = await getPublishedPosts();
const topics = buildTopicGroups(posts, topicDefinitions);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="专题 · KYRIE.DEV" description="按工程主题浏览 KYRIE.DEV 的技术文章。">
  <section class="container page-shell">
    <p class="page-kicker">Topics / {String(topics.length).padStart(2, "0")}</p>
    <h1 class="page-title">专题索引</h1>
    <p class="page-lede">主题不是标签堆积，而是同一类工程问题在不同上下文里的连续观察。</p>

    <div class="topic-list">
      {topics.map((topic, index) => {
        const topicUrl = joinBase(base, `topics/${topic.slug}/`);
        const previewPosts = topic.posts.slice(0, 4);

        return (
          <section class="topic-row">
            <div class="topic-name">
              <span class="mono">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h2><a href={topicUrl}>{topic.name}</a></h2>
                <p>{topic.description}</p>
              </div>
              <small class="mono">{topic.posts.length} POSTS</small>
            </div>

            <div class="topic-preview">
              <div class="topic-posts">
                {previewPosts.map((post) => (
                  <a href={joinBase(base, `articles/${post.id}/`)}>{post.data.title}</a>
                ))}
              </div>
              <a class="view-topic mono" href={topicUrl}>
                查看全部 {topic.posts.length} 篇
                <ArrowRight size={15} stroke-width={2} aria-hidden="true" />
              </a>
            </div>
          </section>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .topic-list {
    margin-top: 62px;
    border-top: 1px solid var(--ink);
  }

  .topic-row {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 48px;
    padding-block: 34px;
    border-bottom: 1px solid var(--line);
  }

  .topic-name {
    display: grid;
    grid-template-columns: 34px 1fr auto;
    gap: 12px;
    align-items: start;
  }

  .topic-name > span,
  .topic-name small {
    padding-top: 7px;
    color: var(--muted-ink);
    font-size: 0.65rem;
    font-weight: 700;
  }

  h2 {
    margin: 0;
    font-size: 1.35rem;
    letter-spacing: 0;
  }

  h2 a:hover {
    color: var(--blue);
  }

  .topic-name p {
    margin: 6px 0 0;
    color: var(--muted-ink);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .topic-preview {
    display: grid;
    gap: 20px;
  }

  .topic-posts {
    display: grid;
    gap: 11px;
  }

  .topic-posts a {
    width: fit-content;
    max-width: 100%;
    font-size: 0.9rem;
    overflow-wrap: anywhere;
  }

  .topic-posts a:hover {
    color: var(--blue);
  }

  .view-topic {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .view-topic:hover {
    color: var(--blue);
  }

  @media (max-width: 760px) {
    .topic-row {
      grid-template-columns: 1fr;
      gap: 22px;
    }
  }

  @media (max-width: 480px) {
    .topic-name {
      grid-template-columns: 28px 1fr;
    }

    .topic-name small {
      display: none;
    }
  }
</style>
